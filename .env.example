# ---- SQLite (OAuth + audit log) ----
# Toda escrita do MCP (clients OAuth, codes, refresh tokens, audit) vai
# pra um SQLite local no volume montado.
# Em prod aponta pra dentro do volume Docker (ex: /data/app.db).
# Em dev local: ./data/app.db
SQLITE_PATH=./data/app.db

# ---- OAuth (Google Workspace) ----
# URL pública do servidor MCP (sem barra no fim). Usada como issuer/audience nos JWTs.
OAUTH_ISSUER=https://mcp.ipbx.vivavox.com.br

# Credenciais do OAuth Client criado em console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Restringe login ao Workspace Vivavox (hd = hosted domain do Google).
ALLOWED_GOOGLE_HD=vivavox.com.br

# Chave de assinatura dos JWTs que ESTE servidor emite (HS256).
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_JWT_SECRET=

# ---- Token de serviço (opcional) ----
# Bearer estático para chamadas internas (cron, healthcheck, scripts).
# Convive com o fluxo OAuth: tokens emitidos via /token também valem.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_AUTH_TOKEN=

# ---- MySQL (fonte de dados do IPBX) ----
# Banco que as tools do MCP consultam. Use um usuário DEDICADO e
# SOMENTE LEITURA (GRANT SELECT) — o MCP só expõe dados, não escreve.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Tamanho do pool de conexões (mysql2). O servidor é stateless por
# request, mas o pool é singleton no processo — igual ao getDb().
MYSQL_POOL_LIMIT=5

# TLS na conexão. Deixe vazio se o MySQL está na mesma rede privada;
# use "required" se o tráfego sai da máquina.
MYSQL_SSL=

# ---- Tenant (mono-tenant) ----
# O banco é multi-tenant (uma instância por cliente, ver tabela `ipbx`),
# mas ESTA instância do MCP atende UM tenant só. Todas as queries são
# filtradas por este id — `branch`, `queue`, `trunk`, `ivr` etc. têm
# coluna `ipbx_id`.
#
# É o limite de isolamento entre clientes: nenhuma tool aceita ipbx_id
# como parâmetro, justamente pra que o valor não possa ser trocado em
# tempo de chamada. Um MCP por tenant, cada um com seu .env e subdomínio.
#
# Consulte os ids com: SELECT id, shortname, fullname FROM ipbx;
IPBX_ID=

