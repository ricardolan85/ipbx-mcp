# ---- API de portabilidade (provedora) ----
# Endpoint interno: GET {URL}/portabilidade/{numero} com header x-api-key.
# Retorno: {numero, encontrado, idoperadora, cio, portado}
PORTABILIDADE_API_URL=http://138.94.55.156:50500
PORTABILIDADE_API_KEY=

# ---- SQLite (OAuth + audit log) ----
# MySQL acima e da provedora (read-only via consultaTN). Tudo que e
# escrita do MCP (clients OAuth, codes, refresh tokens, audit) vai
# pra um SQLite local no volume montado.
# Em prod aponta pra dentro do volume Docker (ex: /data/app.db).
# Em dev local: ./data/app.db
SQLITE_PATH=./data/app.db

# ---- OAuth (Google Workspace) ----
# URL pública do servidor MCP (sem barra no fim). Usada como issuer/audience nos JWTs.
OAUTH_ISSUER=https://mcp.portabilidade.vivavox.com.br

# Credenciais do OAuth Client criado em console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Restringe login ao Workspace Vivavox (hd = hosted domain do Google).
ALLOWED_GOOGLE_HD=vivavox.com.br

# Chave de assinatura dos JWTs que ESTE servidor emite (HS256).
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_JWT_SECRET=

# ---- Token de serviço (opcional) ----
# Bearer estático para chamadas internas (cron, healthcheck, scripts).
# Convive com o fluxo OAuth: tokens emitidos via /token também valem.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_AUTH_TOKEN=

