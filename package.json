{
  "name": "ipbx-mcp",
  "version": "0.1.0",
  "description": "MCP server IPBX (Streamable HTTP + OAuth/bearer + SQLite audit)",
  "type": "module",
  "bin": {
    "ipbx-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "inspect": "npx @modelcontextprotocol/inspector"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^12.10.0",
    "express": "^5.0.0",
    "jose": "^6.2.3",
    "mysql2": "^3.23.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22"
  }
}
